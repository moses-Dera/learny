// Single source of truth for the database.
// Never alter the DB directly — all changes go through `prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum VideoStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  REFUNDED
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String? // null for OAuth users — never store plaintext
  role                       Role      @default(STUDENT)
  isBanned                   Boolean   @default(false)
  stripeAccountId            String?   @unique
  stripeAccountSetupComplete Boolean   @default(false)
  notifyCourseUpdates        Boolean   @default(true)
  notifyMarketing            Boolean   @default(false)
  deletedAt                  DateTime? // soft delete only
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  courses        Course[]         @relation("InstructorCourses")
  enrollments    Enrollment[]
  reviews        Review[]
  lessonProgress LessonProgress[]
  auditLogs      AuditLog[]       @relation("ActorAuditLogs")
  notifications  Notification[]

  @@index([email])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── LMS Core Models ──────────────────────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  courses Course[]
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String       @db.Text
  price        Decimal      @db.Decimal(10, 2)
  status       CourseStatus @default(DRAFT)
  level        CourseLevel  @default(BEGINNER)
  thumbnailUrl String?
  instructorId String
  categoryId   String?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructor  User         @relation("InstructorCourses", fields: [instructorId], references: [id])
  category    Category?    @relation(fields: [categoryId], references: [id])
  sections    Section[]
  enrollments Enrollment[]
  reviews     Review[]

  // Covers the most common browse query: published courses by category
  @@index([status, categoryId])
  @@index([instructorId])
  @@index([slug])
}

model Section {
  id       String @id @default(cuid())
  title    String
  order    Int
  courseId String

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id              String      @id @default(cuid())
  title           String
  description     String?     @db.Text
  muxPlaybackId   String?
  muxUploadId     String?     @unique // idempotency key for Mux webhook
  muxAssetId      String?
  videoStatus     VideoStatus @default(PENDING)
  durationSeconds Int?
  order           Int
  isFree          Boolean     @default(false)
  sectionId       String

  section  Section          @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([sectionId])
}

model Enrollment {
  id                    String    @id @default(cuid())
  userId                String
  courseId              String
  stripePaymentIntentId String?   @unique // idempotency key — unique constraint at DB level
  progressPercent       Int       @default(0) // materialized — updated on LessonProgress upsert
  enrolledAt            DateTime  @default(now())
  completedAt           DateTime?

  user    User     @relation(fields: [userId], references: [id])
  course  Course   @relation(fields: [courseId], references: [id])
  payment Payment?

  // Prevents double enrollment at DB level — not just app level
  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  courseId              String
  enrollmentId          String        @unique
  stripeSessionId       String        @unique
  stripePaymentIntentId String        @unique
  // Amount stored at checkout time — immutable financial record
  // Never recalculate from Course.price for financial records
  amount                Decimal       @db.Decimal(10, 2)
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])

  @@index([userId])
  @@index([stripePaymentIntentId])
}

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  watchedSeconds Int      @default(0)
  completed      Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id])
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  // Composite unique key — upsert is the primary access pattern
  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int // 1–5
  body      String?  @db.Text
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId]) // one review per student per course
  @@index([courseId])
}

// Append-only — never update or delete rows
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String // ban | unban | publish | reject | refund | role_change
  targetId   String
  targetType String // user | course | payment
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation("ActorAuditLogs", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String   @db.Text
  isRead    Boolean  @default(false)
  link      String?  // Optional URL to redirect to when clicked
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
